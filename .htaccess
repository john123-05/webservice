Options -Indexes

# Remove .html extension from URLs
RewriteEngine On

# If the request is for an actual file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# If the request is not already ending in .html, try serving the .html version
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# Redirect /index or /index.html to / (clean root)
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^ / [R=301,L]

# Redirect *.html requests to clean URL (no .html)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /(.+)\.html\ HTTP [NC]
RewriteRule ^ /%1 [R=301,L]
